{
  "$ref": "#/definitions/achievements",
  "definitions": {
    "achievements": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "Article",
            "Award",
            "Patent"
          ]
        },
        "author": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "errorMessage": {
            "pattern": "Date must be in YYYY-MM-DD format"
          }
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "logo": {
          "type": "string",
          "pattern": "\\.(jpg|jpeg|png|webp|svg)$",
          "errorMessage": {
            "pattern": "Image must be a valid image file"
          }
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "errorMessage": {
            "pattern": "Slug must contain only lowercase letters, numbers, and hyphens"
          }
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "type",
        "author",
        "date",
        "logo"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}