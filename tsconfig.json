{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "incremental": true,
    "baseUrl": ".",
    "types": ["astro/client"],
    "paths": {
      "@layouts": ["src/layouts"],
      "@layouts/*": ["src/layouts/*"],
      "@components/*": ["src/components/*"],
      "@utils/*": ["src/utils/*"],
      "@public/*": ["public/*"]
    }
  }
}
