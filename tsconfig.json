{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "incremental": true,
    "baseUrl": ".",
    "types": ["astro/client"],
    "paths": {
      "@layouts/*": ["src/layouts/*"],
      "@sections/*": ["src/sections/*"],
      "@components/*": ["src/components/*"],
      "@assets/*": ["src/assets/*"]
    }
  }
}
