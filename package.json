{
  "name": "jonathontoon.com",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky install",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "clean": "git clean --interactive -dx --exclude .env.local --exclude \".env.*.local\" --exclude node_modules/ --exclude .husky/",
    "lint": "npm-run-all --parallel lint:astro lint:js+ts lint:format lint:types",
    "lint:astro": "astro check",
    "lint:js+ts": "eslint --ext .astro,.js,.jsx,.cjs,.ts,.tsx,.cts --ignore-path .gitignore .",
    "lint:format": "prettier --check .",
    "lint:types": "tsc --noEmit",
    "lint:fix": "npm-run-all --serial lint:fix:*",
    "lint:fix:js+ts": "pnpm run lint:js+ts --fix",
    "lint:fix:format": "prettier --write ."
  },
  "dependencies": {
    "@astrojs/tailwind": "5.1.0",
    "@fontsource-variable/archivo": "^5.0.19",
    "astro": "4.9.2",
    "astro-compress": "^2.2.26",
    "astro-icon": "^1.1.0",
    "tailwindcss": "3.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.7.0",
    "@types/node": "20.12.12",
    "@typescript-eslint/eslint-plugin": "7.11.0",
    "@typescript-eslint/parser": "7.11.0",
    "eslint": "9.3.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-config-airbnb-typescript": "18.0.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-import-resolver-typescript": "3.6.1",
    "eslint-plugin-astro": "1.2.0",
    "eslint-plugin-eslint-comments": "3.2.0",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-jsx-a11y": "6.8.0",
    "eslint-plugin-regexp": "2.6.0",
    "eslint-plugin-simple-import-sort": "12.1.0",
    "eslint-plugin-tailwindcss": "3.17.0",
    "husky": "9.0.11",
    "nano-staged": "0.8.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.2.5",
    "prettier-plugin-astro": "0.14.0",
    "prettier-plugin-tailwindcss": "0.5.14",
    "typescript": "5.4.5"
  },
  "packageManager": "pnpm@9.1.3",
  "nano-staged": {
    "*": "prettier --write --ignore-unknown",
    "*.{astro,js,jsx,cjs,ts,tsx,cts}": "eslint --fix"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "rollup"
      ]
    }
  }
}