---
import type { HTMLAttributes } from "astro/types";
import List from "@components/List.astro";

interface Props extends HTMLAttributes<"ul"> {
  class?: string;
}

const { class: className = "", ...attrs } = Astro.props;
---

<List
  {...attrs}
  class:list={[
    "p-2",
    "sm:p-4",
    "bg-zinc-50",
    "rounded-2xl",
    "space-y-2",
    "sm:space-y-4",
    className
  ]}
  `
>
  <slot />
</List>
