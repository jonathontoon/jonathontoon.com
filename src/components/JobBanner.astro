---
import View from "@components/View.astro";
import TextLink from "@components/TextLink.astro";
import Text from "./Text.astro";
---

<View
  class="w-full transform bg-neutral-100 px-6 py-5 shadow-sm transition-transform duration-300 md:text-center dark:bg-neutral-800 dark:shadow-stone-700/20"
>
  <Text class="text-base tracking-wide text-neutral-700 dark:text-neutral-300">
    [deploy-test-e51] I'm always on the lookout for what's next. Interested in working together?
    <TextLink
      href="https://cal.com/jonathontoon/hire-me"
      target="_blank"
      rel="noopener noreferrer"
      class="inline tracking-normal"
      >Book a call.
    </TextLink>
  </Text>
</View>
