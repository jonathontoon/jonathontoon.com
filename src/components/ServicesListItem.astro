---
import type { HTMLAttributes } from "astro/types";
import ListItem from "@components/ListItem.astro";

interface Props extends HTMLAttributes<"div"> {
  class?: string;
}

const { class: classList = "", title, ...attrs } = Astro.props;
---

<ListItem
  {...attrs}
  class={`bg-zinc-950 rounded-xl flex flex-col space-y-4 p-4 ${classList}`}
>
  <slot />
</ListItem>
