---
import type { HTMLAttributes } from "astro/types";
import ListItem from "@components/ListItem.astro";

interface Props extends HTMLAttributes<"div"> {
  class?: string;
}

const { class: className = "", title, ...attrs } = Astro.props;
---

<ListItem
  {...attrs}
  class:list={[
    "bg-zinc-200",
    "rounded-xl",
    "flex",
    "flex-col",
    "space-y-8",
    "sm:space-y-7",
    "p-4",
    className
  ]}
>
  <slot />
</ListItem>
