---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"p"> {
  class?: string;
}

const { class: className = "", ...attrs } = Astro.props;
---

<p
  {...attrs}
  class:list={[
    "text-lg",
    "leading-snug",
    "sm:text-xl",
    "sm:leading-normal",
    "font-normal",
    "leading-relaxed",
    "tracking-tight",
    className
  ]}
>
  <slot />
</p>
