---
import type { HTMLAttributes } from "astro/types";
import { cn } from "@utils/cn";
import Link from "./Link.astro";

interface Props extends HTMLAttributes<"a"> {
  class?: string | undefined;
  href: string;
  rel?: string | undefined;
  target?: string | undefined;
}

const { class: className = "", rel = "preload", target = "_self", ...attrs } = Astro.props;
---

<Link class={cn("text-base text-blue-600 font-bold px-3 py-1.5 bg-blue-50 hover:bg-blue-100 rounded-xl transition-colors duration-300 ease-in-out", className)} rel={rel} target={target} {...attrs}><slot /></Link>
