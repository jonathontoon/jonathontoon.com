---
import { Icon } from "astro-icon/components";
import Link from "./Link.astro";

interface BreadcrumbItem {
  label: string;
  href: string;
}

function pathToLabel(segment: string): string {
  // Convert URL segment to readable label
  return segment
    .split('-')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

function generateBreadcrumbs(pathname: string): BreadcrumbItem[] {
  if (pathname === '/') {
    return [];
  }

  const segments = pathname.split('/').filter(segment => segment !== '');
  const breadcrumbs: BreadcrumbItem[] = [];
  let currentPath = '';

  segments.forEach((segment) => {
    currentPath += `/${segment}`;
    breadcrumbs.push({
      label: pathToLabel(segment),
      href: currentPath
    });
  });

  return breadcrumbs;
}

const breadcrumbs = generateBreadcrumbs(Astro.url.pathname);
---

{breadcrumbs.length > 0 && (
  <header class="flex items-center gap-x-2 px-2">
    <Link href="/" class="no-underline flex items-center">
      <Icon name="solid-house" class="text-stone-900 w-6 h-6" />
    </Link>
    {breadcrumbs.map((crumb) => (
      <Fragment>
        <Icon name="stroke-arrow-small-right" class="text-stone-400 w-6 h-6" />
        <Link href={crumb.href} class="no-underline text-stone-900 font-bold">
          {crumb.label}
        </Link>
      </Fragment>
    ))}
  </header>
)}