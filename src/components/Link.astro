---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'a'> {
    href?: string;
    class?: string;
};

const { href, class: classList = "", ...attrs } = Astro.props;
---
<a rel="prefectch" href={href} class:list={`underline hover:no-underline ${classList}`} {...attrs}><slot/></a>
