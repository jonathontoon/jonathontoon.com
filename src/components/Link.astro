---
import type { HTMLAttributes } from "astro/types";
import { twMerge } from "tailwind-merge";

interface Props extends HTMLAttributes<"a"> {
  href?: string;
  class?: string;
}

const { href, class: classList = "", ...attrs } = Astro.props;
---

<a
  rel="prefectch"
  href={href}
  class:list={[
    twMerge("cursor-pointer underline hover:no-underline", classList)
  ]}
  {...attrs}><slot /></a
>
