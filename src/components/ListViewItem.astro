---
import Link from "./Link.astro";
import View from "./View.astro";

interface Props {
  href?: string;
  target?: string;
  class?: string;
}

const { href, target, class: className = "", ...attrs } = Astro.props;
---

<View class={className} {...attrs}>
  {
    href ? (
      <Link
        href={href}
        target={target}
        class="flex flex-row justify-between gap-x-2 rounded-2xl p-2 no-underline transition-colors duration-300 ease-in-out hover:bg-stone-950/5"
      >
        <View class="flex flex-row gap-x-3">
          <slot name="image" />
          <View class="flex flex-col justify-center">
            <slot name="content" />
          </View>
        </View>
        <slot name="action" />
      </Link>
    ) : (
      <View class="flex flex-row justify-between gap-x-2 p-2">
        <View class="flex flex-row gap-x-3">
          <slot name="image" />
          <View class="flex flex-col justify-center">
            <slot name="content" />
          </View>
        </View>
        <slot name="action" />
      </View>
    )
  }
</View>
