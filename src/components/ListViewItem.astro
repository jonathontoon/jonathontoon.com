---
import Link from "./Link.astro";
import View from "./View.astro";

interface Props {
  href?: string;
  target?: string;
  class?: string;
}

const { href, target, class: className = "", ...attrs } = Astro.props;
---

<View class={className} {...attrs}>
  {
    href ? (
      <Link
        href={href}
        target={target}
        class="flex flex-row justify-between gap-x-2 rounded-3xl p-2 no-underline transition-colors duration-300 ease-in-out hover:bg-neutral-950/5 md:gap-x-4 dark:hover:bg-neutral-50/5"
      >
        <View class="flex flex-row gap-x-3 md:gap-x-4">
          <slot name="image" />
          <View class="flex flex-col justify-center gap-y-2 md:gap-y-1.5">
            <slot name="content" />
          </View>
        </View>
        <slot name="action" />
      </Link>
    ) : (
      <View class="flex flex-row justify-between gap-x-2 p-2 md:gap-x-4">
        <View class="flex flex-row gap-x-3 md:gap-x-4">
          <slot name="image" />
          <View class="flex flex-col justify-center gap-y-2 md:gap-y-1.5">
            <slot name="content" />
          </View>
        </View>
        <slot name="action" />
      </View>
    )
  }
</View>
