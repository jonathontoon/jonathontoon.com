---
import { Icon } from "astro-icon/components";
import View from "./View.astro";

interface Props {
  class?: string;
}

const { class: className = "", ...attrs } = Astro.props;
---

<View class={className} {...attrs}>
  <Icon
    name="stroke-arrow-small-right"
    class="aspect-square h-full w-8 text-stone-400 md:w-10 dark:text-stone-500"
  />
</View>
