---
import { Icon } from "astro-icon/components";
import View from "./View.astro";

interface Props {
  class?: string;
  external?: boolean;
}

const { class: className = "", external = true, ...attrs } = Astro.props;
---

<View class={className} {...attrs}>
  <Icon
    name={external
      ? "stroke-arrow-fromSquare-upRight"
      : "stroke-arrow-small-right"}
    class:list={[
      "aspect-square h-full text-stone-400 dark:text-stone-500",
      external ? "mr-2 w-4 md:w-8" : "w-8 md:w-10"
    ]}
  />
</View>
