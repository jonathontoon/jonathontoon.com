---
import type { HTMLAttributes } from "astro/types"

interface Props extends HTMLAttributes<"h2"> {
  class?: string
}

const { class: classList = "", ...attrs } = Astro.props
---

<h2
  {...attrs}
  class:list={[
    "align-middle text-xl font-semibold leading-tight tracking-tight",
    classList
  ]}
>
  <slot />
</h2>
