---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"h2"> {
  class?: string;
}

const { class: className = "", ...attrs } = Astro.props;
---

<h2
  class:list={[
    "align-middle",
    "tracking-tight",
    "text-2xl",
    "font-semibold",
    "sm:!text-3xl",
    className
  ]}
  {...attrs}
>
  <slot />
</h2>
