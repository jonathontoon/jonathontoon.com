---
import TextButton from './TextButton.astro';
import View from './View.astro';

interface Props {
  href: string;
  target?: string;
}

const { href, target = "_blank", ...attrs } = Astro.props;
---
<View class="flex items-center justify-center" {...attrs}>
  <TextButton 
    href={href} 
    target={target}
  >
    <slot>Visit</slot>
  </TextButton>
</View>