---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"h3"> {
  class?: string;
}

const { class: classList = "", ...attrs } = Astro.props;
---

<h3
  {...attrs}
  class:list={["align-middle text-lg font-medium tracking-normal", classList]}
>
  <slot />
</h3>
