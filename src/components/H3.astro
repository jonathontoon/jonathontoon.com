---
import type { HTMLAttributes } from "astro/types";
import { twMerge } from "tailwind-merge";

interface Props extends HTMLAttributes<"h3"> {
  class?: string;
}

const { class: classList = "", ...attrs } = Astro.props;
---

<h3
  {...attrs}
  class:list={[
    twMerge(
      "font-primary m-0 align-middle text-lg font-medium tracking-normal",
      classList
    )
  ]}
>
  <slot />
</h3>
