---
import type { HTMLAttributes } from "astro/types";
import { twMerge } from "tailwind-merge";

export interface LinkProps extends HTMLAttributes<"a"> {
  href?: string;
  class?: string;
}

const { href, class: classList = "", ...attrs } = Astro.props;
---

<a
  rel="prefectch"
  href={href}
  class:list={[
    twMerge(
      "block cursor-pointer rounded-xl bg-zinc-800 p-4 py-2 text-center align-middle text-base font-normal text-zinc-50 transition-colors duration-300",
      classList
    )
  ]}
  {...attrs}><slot /></a
>
