---
import type { HTMLAttributes } from "astro/types";

export interface LinkProps extends HTMLAttributes<"a"> {
  href?: string;
  class?: string;
}

const { href, class: classList = "", ...attrs } = Astro.props;
---

<a
  rel="prefectch"
  href={href}
  class:list={[
    "inline-block cursor-pointer px-6 py-2 text-center text-base font-medium text-slate-50 transition-colors duration-300 [:where(&)]:bg-slate-800 [:where(&)]:hover:bg-slate-900",
    classList
  ]}
  {...attrs}><slot /></a
>
