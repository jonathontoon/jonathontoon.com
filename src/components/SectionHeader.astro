---
import { Icon } from "astro-icon/components"
import type { HTMLAttributes } from "astro/types"
import H2 from "@components/H2.astro"
import Paragraph from "@components/Paragraph.astro"

interface Props extends HTMLAttributes<"div"> {
  class?: string
  iconName: string
  title: string
  description?: string
}

const {
  class: classList = "",
  iconName,
  title,
  description,
  ...attrs
} = Astro.props
---

<div class:list={["space-y-2", classList]} {...attrs}>
  <div class:list={"flex flex-row content-center space-x-2 text-zinc-50"}>
    <Icon
      name={iconName}
      shape-rendering="geometricPrecision"
      class="h-6 w-6"
    />
    <H2>{title}</H2>
  </div>
  {description && <Paragraph class="text-zinc-400">{description}</Paragraph>}
</div>
