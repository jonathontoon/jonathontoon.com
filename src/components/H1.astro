---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"h1"> {
  class?: string;
}

const { class: className = "", ...attrs } = Astro.props;
---

<h1
  class:list={[
    "align-middle",
    "text-2xl",
    "font-bold",
    "tracking-tight",
    className
  ]}
  {...attrs}
>
  <slot />
</h1>
