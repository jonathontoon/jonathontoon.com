---
import ImageLarge from "./ImageLarge.astro";
import View from "./View.astro";

interface Props {
  class?: string;
}

const { class: className = "", ...attrs } = Astro.props;
---

<View class={`relative group ${className}`}>
  <ImageLarge
    class="bg-blue-500 group-hover:invisible"
    src="/images/profile.png"
    alt="Jonathon Toon"
    {...attrs}
  />
  <ImageLarge
    class="bg-blue-500 absolute inset-0 w-24 h-24 invisible group-hover:visible"
    src="/images/profile-blink.png"
    alt="Jonathon Toon"
    {...attrs}
  />
</View>
