---
import SquareImageLarge from "./SquareImageLarge.astro";
import View from "./View.astro";

interface Props {
  class?: string;
}

const { class: className = "", ...attrs } = Astro.props;
---

<View class={`hover:translate-y-0.5 duration-200 ease-in-out flex relative group ${className}`}>
  <SquareImageLarge
    class="bg-blue-500 group-hover:invisible"
    src="/images/profile.png"
    alt="Jonathon Toon"
    {...attrs}
  />
  <SquareImageLarge
    class="invisible absolute inset-0 h-24 w-24 bg-blue-500 group-hover:visible"
    src="/images/profile-blink.png"
    alt="Jonathon Toon"
    {...attrs}
  />
</View>
