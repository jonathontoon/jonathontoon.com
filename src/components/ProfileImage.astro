---
import SquareImageLarge from "./SquareImageLarge.astro";
import View from "./View.astro";

interface Props {
  class?: string;
}

const { class: className = "", ...attrs } = Astro.props;
---

<View
  class={`hover:translate-y-0.5 duration-300 ease-in-out flex relative group ${className}`}
>
  <SquareImageLarge
    class="h-32 w-32 bg-blue-500 group-hover:invisible md:h-36 md:w-36 dark:bg-blue-500"
    src="/images/profile.png"
    alt="Jonathon Toon"
    {...attrs}
  />
  <SquareImageLarge
    class="invisible absolute inset-0 h-32 w-32 bg-blue-500 group-hover:visible md:h-36 md:w-36 dark:bg-blue-500"
    src="/images/profile-blink.png"
    alt="Jonathon Toon"
    {...attrs}
  />
</View>
