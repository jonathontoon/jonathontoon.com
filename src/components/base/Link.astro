---
import type { HTMLAttributes } from "astro/types";
import { cn } from "@utils/cn";

interface Props extends HTMLAttributes<"a"> {
  class?: string | undefined;
  href: string;
  rel?: string | undefined;
  target?: string | undefined;
}

const { class: className = "", rel = "preload", target = "_self", ...attrs } = Astro.props;
---

<a class={cn("font-semibold underline hover:no-underline decoration-from-font underline-offset-2 cursor-pointer", className)} rel={rel} target={target} {...attrs}><slot /></a>
