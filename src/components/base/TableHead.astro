---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"th"> {
  class?: string;
}

const { class: className = "", ...attrs } = Astro.props;
---

<th
  class:list={[
    "border-b-2 border-zinc-100 px-6 py-4 text-xs font-medium uppercase tracking-wide text-zinc-500",
    className,
  ]}
  {...attrs}
>
  <slot />
</th>
