---
import type { HTMLAttributes } from "astro/types";
import { cn } from "@utils/cn";

interface Props extends HTMLAttributes<"input"> {
  class?: string;
  buttonText?: string;
}

const { class: className = "", id = "file-input", ...attrs } = Astro.props;
---

<input class={cn(className)} id={id} type="file" {...attrs} />
