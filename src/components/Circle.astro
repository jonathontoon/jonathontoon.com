<canvas id="canvas" width="120" height="120"></canvas>
<script>
  interface Circle {
    centerX: number;
    centerY: number;
    baseRadius: number;
    amplitude: number;
    frequency: number;
    phase: number;
    phaseIncrement: number;
    fillColor: string;
  }

  const setupCanvas = (
    canvasId: string
  ): { ctx: CanvasRenderingContext2D | null; circles: Circle[] } => {
    const canvas = document.getElementById(canvasId) as HTMLCanvasElement;
    const ctx = canvas.getContext("2d");

    const width = canvas.width;
    const height = canvas.height;
    const baseRadius = Math.min(width, height) / 2.3;
    const amplitude = baseRadius / 10;

    const circles: Circle[] = [
      {
        centerX: width / 2,
        centerY: height / 2,
        baseRadius: baseRadius,
        amplitude: amplitude,
        frequency: 8,
        phase: 5,
        phaseIncrement: 0.02,
        fillColor: "rgba(255, 0, 0)"
      },
      {
        centerX: width / 2,
        centerY: height / 2,
        baseRadius: baseRadius,
        amplitude: amplitude,
        frequency: 8,
        phase: 3,
        phaseIncrement: 0.02,
        fillColor: "rgba(0, 255, 0)"
      },
      {
        centerX: width / 2,
        centerY: height / 2,
        baseRadius: baseRadius,
        amplitude: amplitude,
        frequency: 8,
        phase: 1,
        phaseIncrement: 0.02,
        fillColor: "rgba(0, 0, 255)"
      }
    ];

    return { ctx, circles };
  };

  const updatePhase = (phase: number, increment: number): number => {
    return phase + increment;
  };

  const drawCircle = (ctx: CanvasRenderingContext2D, circle: Circle) => {
    ctx.fillStyle = circle.fillColor;
    ctx.beginPath();
    for (let angle = 0; angle < Math.PI * 2; angle += 0.01) {
      const x =
        circle.centerX +
        (circle.baseRadius +
          circle.amplitude *
            Math.sin(circle.frequency * angle + circle.phase)) *
          Math.cos(angle);
      const y =
        circle.centerY +
        (circle.baseRadius +
          circle.amplitude *
            Math.sin(circle.frequency * angle + circle.phase)) *
          Math.sin(angle);
      if (angle === 0) {
        ctx.moveTo(x, y);
      } else {
        ctx.lineTo(x, y);
      }
    }
    ctx.closePath();
    ctx.fill();
  };

  const animateCircles = (
    ctx: CanvasRenderingContext2D,
    circles: Circle[]
  ): void => {
    ctx.clearRect(0, 0, ctx.canvas.width, ctx.canvas.height);
    ctx.globalCompositeOperation = "source-over";
    ctx.globalCompositeOperation = "lighten";
    circles.forEach((circle) => {
      drawCircle(ctx, circle);
      circle.phase = updatePhase(circle.phase, circle.phaseIncrement);
    });
    requestAnimationFrame(() => animateCircles(ctx, circles));
  };

  const { ctx, circles } = setupCanvas("canvas");
  if (ctx) {
    animateCircles(ctx, circles);
  }
</script>
