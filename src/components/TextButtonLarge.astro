---
import type { HTMLAttributes } from "astro/types";
import { cn } from "@utils/cn";
import TextButton from "./TextButton.astro";

interface Props extends HTMLAttributes<"a"> {
  class?: string | undefined;
  href: string;
  rel?: string | undefined;
  target?: string | undefined;
}

const {
  class: className = "",
  rel = "preload",
  target = "_self",
  ...attrs
} = Astro.props;
---

<TextButton
  class={cn("hover:translate-y-0.5 transition-all duration-300 ease-in-out text-xl py-4 md:py-3 px-4 md:px-5 font-bold rounded-2xl tracking-normal", className)}
  rel={rel}
  target={target}
  {...attrs}><slot /></TextButton
>
