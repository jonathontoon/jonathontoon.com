---
import { cn } from "@utils/cn";
import View from "./View.astro";
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  class?: string;
  lightbox?: boolean;
  src: string | ImageMetadata;
  alt: string;
  widths?: number[];
  sizes?: string;
  formats?: ("webp" | "avif" | "png" | "jpg" | "jpeg")[];
  quality?: number;
  loading?: "lazy" | "eager";
  decoding?: "async" | "sync" | "auto";
}

const {
  class: className = "",
  lightbox = false,
  src,
  alt,
  widths = [320, 640, 768, 1024, 1280],
  sizes = "(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw",
  formats = ["webp", "avif"],
  quality = 80,
  loading = "lazy",
  decoding = "async"
} = Astro.props;
---

{
  lightbox ? (
    <View class="relative px-2 transition-all duration-300 hover:translate-y-0.5 md:-mx-16 md:px-0">
      <Picture
        data-lightbox="true"
        class={cn(
          "w-full cursor-pointer rounded-xl bg-neutral-200 opacity-0 transition-opacity duration-700 ease-out dark:bg-neutral-800",
          className
        )}
        src={src}
        alt={alt}
        widths={widths}
        sizes={sizes}
        formats={formats}
        quality={quality}
        loading={loading}
        decoding={decoding}
      />
    </View>
  ) : (
    <Picture
      class={cn("bg-neutral-200 dark:bg-neutral-800", className)}
      src={src}
      alt={alt}
      widths={widths}
      sizes={sizes}
      formats={formats}
      quality={quality}
      loading={loading}
      decoding={decoding}
    />
  )
}

<script>
  function initLightboxImage(): void {
    const images = document.querySelectorAll(
      "img[data-lightbox='true']"
    ) as NodeListOf<HTMLImageElement>;

    // Set up intersection observer for fade-in effect
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.remove("opacity-0");
          }
        });
      },
      {
        threshold: 0.1
      }
    );

    images.forEach((image) => {
      function openLightbox(): void {
        const event = new CustomEvent("lightbox:open", {
          detail: {
            src: image.src,
            alt: image.alt || ""
          }
        });
        document.dispatchEvent(event);
      }

      // Remove any existing listeners to prevent duplicates
      image.removeEventListener("click", openLightbox);
      image.addEventListener("click", openLightbox);

      // Observe image for fade-in effect
      observer.observe(image);
    });
  }

  // Initialize on page load
  document.addEventListener("DOMContentLoaded", initLightboxImage);

  // Reinitialize on Astro page transitions
  document.addEventListener("astro:page-load", initLightboxImage);
</script>
