---
import { cn } from "@utils/cn";
import Image from "./Image.astro";
import type { ImageMetadata } from "astro";

interface Props {
  class?: string;
  src: string | ImageMetadata;
  alt: string;
  width?: number;
  height?: number;
  format?: "webp" | "avif" | "png" | "jpg" | "jpeg";
  quality?: number;
  loading?: "lazy" | "eager";
}

const {
  class: className = "",
  src,
  alt,
  width = 48,
  height = 48,
  format,
  quality = 80,
  loading = "lazy"
} = Astro.props;
---

<Image
  class={cn(
    "w-12 h-12 rounded-2xl bg-neutral-200 dark:bg-neutral-800 aspect-square object-cover object-center",
    className
  )}
  src={src}
  alt={alt}
  width={width}
  height={height}
  format={format}
  quality={quality}
  loading={loading}
/>
