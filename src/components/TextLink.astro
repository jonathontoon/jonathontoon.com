---
import type { HTMLAttributes } from "astro/types";
import { cn } from "@utils/cn";
import Link from "./Link.astro";

interface Props extends HTMLAttributes<"a"> {
  class?: string | undefined;
  href: string;
  rel?: string | undefined;
  target?: string | undefined;
}

const {
  class: className = "",
  rel = "preload",
  target = "_self",
  ...attrs
} = Astro.props;
---

<Link
  class={cn(
    "text-stone-700 font-bold underline duration-200 transition-all hover:no-underline decoration-2 underline-offset-2",
    className
  )}
  rel={rel}
  target={target}
  {...attrs}><slot /></Link
>
