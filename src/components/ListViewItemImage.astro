---
import SquareImage from "./SquareImage.astro";
import View from "./View.astro";

interface Props {
  src?: string;
  alt?: string;
  class?: string;
}

const { src, alt, class: className = "", ...attrs } = Astro.props;
---

<View class="flex-shrink-0">
  {
    src ? (
      <SquareImage
        src={src}
        alt={alt || ""}
        class="w-20 h-20 md:w-24 md:h-24"
        {...attrs}
      />
    ) : (
      <slot>Image</slot>
    )
  }
</View>
