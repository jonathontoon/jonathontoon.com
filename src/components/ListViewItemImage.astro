---
import Image from './Image.astro';
import View from './View.astro';

interface Props {
  src?: string;
  alt?: string;
  class?: string;
}

const { src, alt, class: className = "", ...attrs } = Astro.props;
---

<View class="flex-shrink-0">
  {src ? (
    <Image 
      src={src} 
      alt={alt || ""}
      class="w-[72px] h-[72px]"
      {...attrs}
    />
  ) : (
    <slot>Image</slot>
  )}
</View>