---
import type { HTMLAttributes } from "astro/types";
import { Icon } from "astro-icon/components";

import H3 from "@components/H3.astro";
import Paragraph from "@components/Paragraph.astro";

interface Props extends HTMLAttributes<'div'> {
    class?: string;
    iconName: string;
    title: string;
    description: string;
};

const { class: classList = "", iconName, title, description, ...attrs } = Astro.props;
---
<div { ...attrs} class:list={`w-full max-w-50 p-4 border-2 rounded-2xl flex flex-col justify-between ${classList}`}>
    <Icon
        name={iconName}
        size={32}
        shape-rendering={"geometricPrecision"}
        width={32}
        height={32}
        viewBox={"0 0 32 32"} 
    />
    <div class="mt-6">
        <H3 class="mb-2">
            {title}
        </H3>
        <Paragraph class="text-zinc-50 !leading-5 !mb-0">
            {description}
        </Paragraph>
    </div>
</div>