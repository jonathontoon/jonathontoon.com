---
import CollapsableListItem from "@components/CollapsableListItem.astro";
import H2 from "@components/H2.astro";
import H3 from "@components/H3.astro";
import List from "@components/List.astro";
import Paragraph from "@components/Paragraph.astro";
import Section from "@components/Section.astro";
---

<Section id="faqs" class="pb-20">
  <div class="space-y-2">
    <H2>FAQs</H2>
    <div class="space-y-1">
      <Paragraph>
        Got a question? You may find your answer here. If not, don't hesitate to
        reach out and ask. I usually respond in no more than 2 business days.
      </Paragraph>
    </div>
  </div>
  <List>
    <CollapsableListItem>
      <H3 slot="collapsable-list-item-title" class="text-base">
        What support can I expect to receive as an individual?
      </H3>
      <Paragraph slot="collapsable-list-item-description">
        I happily offer a free initial session hosted on ADPList to discuss your
        goals and how I work. Book a call.
      </Paragraph>
    </CollapsableListItem>
    <CollapsableListItem>
      <H3 slot="collapsable-list-item-title" class="text-base">
        How do I know if this type of individual coaching is right for me?
      </H3>
      <Paragraph slot="collapsable-list-item-description">
        I happily offer a free initial session hosted on ADPList to discuss your
        goals and how I work. Book a call.
      </Paragraph>
    </CollapsableListItem>
    <CollapsableListItem>
      <H3 slot="collapsable-list-item-title" class="text-base">
        What happens after I subscribe?
      </H3>
      <Paragraph slot="collapsable-list-item-description">
        I happily offer a free initial session hosted on ADPList to discuss your
        goals and how I work. Book a call.
      </Paragraph>
    </CollapsableListItem>
    <CollapsableListItem>
      <H3 slot="collapsable-list-item-title" class="text-base">
        What support can I expect to receive for an organization?
      </H3>
      <Paragraph slot="collapsable-list-item-description">
        I happily offer a free initial session hosted on ADPList to discuss your
        goals and how I work. Book a call.
      </Paragraph>
    </CollapsableListItem>
    <CollapsableListItem>
      <H3 slot="collapsable-list-item-title" class="text-base">
        Do you provide any discounts?
      </H3>
      <Paragraph slot="collapsable-list-item-description">
        I happily offer a free initial session hosted on ADPList to discuss your
        goals and how I work. Book a call.
      </Paragraph>
    </CollapsableListItem>
    <CollapsableListItem>
      <H3 slot="collapsable-list-item-title" class="text-base">
        How do I manage my subscription?
      </H3>
      <Paragraph slot="collapsable-list-item-description">
        I happily offer a free initial session hosted on ADPList to discuss your
        goals and how I work. Book a call.
      </Paragraph>
    </CollapsableListItem>
    <CollapsableListItem>
      <H3 slot="collapsable-list-item-title" class="text-base">
        Can I hire you for product design work?
      </H3>
      <Paragraph slot="collapsable-list-item-description">
        I happily offer a free initial session hosted on ADPList to discuss your
        goals and how I work. Book a call.
      </Paragraph>
    </CollapsableListItem>
  </List>
</Section>
