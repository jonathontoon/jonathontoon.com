---
import { Header, Section, Link, Div, H1, H2, H3, Paragraph } from "@components/base";
import { ProfileImage, ListView, ListViewItem, ListViewItemImage, ListViewItemTitle, ListViewItemMeta, ListViewItemChevron, ListViewItemLink } from "@components/common";
import { Layout } from "@layouts";
import { getCollection } from "astro:content";

const experience = await getCollection("experience");
const sortedExperience = experience.sort((a, b) => 
  new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime()
);

const mentorship = await getCollection("mentorship");
const sortedMentorship = mentorship.sort((a, b) => {
  const priceA = parseFloat(a.data.price.replace(/[^\d.]/g, ''));
  const priceB = parseFloat(b.data.price.replace(/[^\d.]/g, ''));
  return priceA - priceB;
});

const projects = await getCollection("projects");
const sortedProjects = projects.sort((a, b) => 
  new Date(b.data.releaseDate).getTime() - new Date(a.data.releaseDate).getTime()
);

const education = await getCollection("education");
const sortedEducation = education.sort((a, b) => 
  new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime()
);

const achievements = await getCollection("achievements");
const sortedAchievements = achievements.sort((a, b) => 
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const appendix = await getCollection("appendix");
const sortedAppendix = appendix.sort((a: any, b: any) => 
  a.data.title.localeCompare(b.data.title)
);

function formatDateRange(startDate: string, endDate?: string): string {
  const startYear = new Date(startDate).getFullYear();
  const endYear = endDate ? new Date(endDate).getFullYear() : "Now";
  
  if (endYear !== "Now" && startYear === endYear) {
    return `${startYear}`;
  }
  
  return `${startYear} — ${endYear}`;
}
---

<Layout
  title="Jonathon Toon | Home"
  description="Jonathon Toon is a software designer, leader, and mentor, living and working remotely in Aotearoa New Zealand. He has a passion for creating impactful digital experiences and fostering innovation in teams."
  keywords="design, software, product, fractional, leadership, new zealand, aoteoroa, technology, typescript, start ups, engineering, mentorship, coaching, adplist"
  twitterHandle="@jonathontoon"
  canonicalUrl="https://www.jonathontoon.com/"
  ogImage="/images/og-image.png"
>
  <Header class="flex flex-row">
    <Div class="px-2">
      <Link href="/" class="block w-24">
        <ProfileImage class="w-full aspect-square bg-blue-500 rounded-xl" />
      </Link>
    </Div>
  </Header>
  <Section class="flex flex-col gap-y-4">
    <H1 class="font-semibold text-3xl md:text-2xl tracking-tight px-2">Nice to meet you, I’m Jonathon.</H1>
    <Paragraph class="text-stone-700 px-2">A versatile software designer, leader, and mentor, living and working remotely in Aotearoa New Zealand.</Paragraph>
    <Paragraph class="text-stone-700 indent-4 px-2">For the past 15 years, I’ve worked across the organizational stack cultivating and leading teams, while designing and shipping products at innovative companies in Asia, Oceania, and North America.</Paragraph>
    <Paragraph class="text-stone-700 indent-4 px-2">In that time, I’ve built deep, hands-on expertise in product, brand and engineering, and learned how to bring those disciplines together to create products that make a real impact.</Paragraph>
  </Section>
  <Section class="flex flex-col gap-y-2">
    <H2 class="font-semibold text-xl tracking-normal px-2">Experience</H2>
    <ListView>
      {sortedExperience.map((experience) => (
        <ListViewItem href={`/experience/${experience.slug}`}>
          <ListViewItemImage 
            slot="image" 
            src={experience.data.logo ? `/${experience.data.logo}` : undefined}
            alt={`${experience.data.title} logo`}
          />
          <Fragment slot="content">
            <ListViewItemTitle>{experience.data.title}</ListViewItemTitle>
            <ListViewItemMeta class="text-stone-700 text-base md:hidden">{`${experience.data.focus}`}</ListViewItemMeta>
            <ListViewItemMeta class="text-stone-500 text-sm md:hidden">{`${formatDateRange(experience.data.startDate, experience.data.endDate)}`}</ListViewItemMeta>
            <ListViewItemMeta class="text-stone-500 text-base hidden md:block">{`${experience.data.focus} · ${formatDateRange(experience.data.startDate, experience.data.endDate)}`}</ListViewItemMeta>
          </Fragment>
          <ListViewItemChevron slot="action" />
        </ListViewItem>
      ))}
    </ListView>
  </Section>
  <Section class="flex flex-col gap-y-2">
    <H3 class="font-semibold text-xl tracking-normal px-2">Mentorship</H3>
    <Paragraph class="text-stone-700 px-2 pb-2">Through both one-off and recurring sessions I help designers, product people and founders navigate challenges through practical, honest, actionable mentorship.</Paragraph>
    <ListView>
      {sortedMentorship.map((mentorship) => (
        <ListViewItem>
          <ListViewItemImage 
            slot="image" 
            src={mentorship.data.logo ? `/${mentorship.data.logo}` : undefined}
            alt={`${mentorship.data.name} logo`}
          />
          <Fragment slot="content">
            <ListViewItemTitle>{mentorship.data.name}</ListViewItemTitle>
            <ListViewItemMeta class="text-stone-700 text-base md:hidden">{mentorship.data.length}</ListViewItemMeta>
            <ListViewItemMeta class="text-stone-500 text-sm md:hidden">{mentorship.data.price}</ListViewItemMeta>
            <ListViewItemMeta class="text-stone-500 text-base hidden md:block">{`${mentorship.data.price} · ${mentorship.data.length}`}</ListViewItemMeta>
          </Fragment>
          {mentorship.data.url && (
            <ListViewItemLink href={mentorship.data.url} slot="action">
              Schedule
            </ListViewItemLink>
          )}
        </ListViewItem>
      ))}
    </ListView>
  </Section>
  <Section class="flex flex-col gap-y-2">
    <H2 class="font-semibold text-xl tracking-normal px-2">Projects</H2>
    <Paragraph class="text-stone-700 px-2 pb-2">I love to build things on my own. Either to explore new technologies, to make a little pocket money, or simply just for fun.</Paragraph>
    <ListView>
      {sortedProjects.map((project) => (
        <ListViewItem>
          <ListViewItemImage 
            slot="image" 
            src={project.data.logo ? `/${project.data.logo}` : undefined}
            alt={`${project.data.name} logo`}
          />
          <Fragment slot="content">
            <ListViewItemTitle>{project.data.name}</ListViewItemTitle>
            <ListViewItemMeta class="text-stone-700 text-base md:hidden">{project.data.technology.join(", ")}</ListViewItemMeta>
            <ListViewItemMeta class="text-stone-500 text-sm md:hidden">{new Date(project.data.releaseDate).getFullYear()}</ListViewItemMeta>
            <ListViewItemMeta class="text-stone-500 text-base hidden md:block">{`${project.data.technology.join(", ")} · ${new Date(project.data.releaseDate).getFullYear()}`}</ListViewItemMeta>
          </Fragment>
          {project.data.url && (
            <ListViewItemLink href={project.data.url} slot="action" />
          )}
        </ListViewItem>
      ))}
    </ListView>
  </Section>
  <Section class="flex flex-col gap-y-2">
    <H2 class="font-semibold text-xl tracking-normal px-2">Patents, Publications, Awards</H2>
    <Paragraph class="text-stone-700 px-2 pb-2">Highlights from my career and education which have been picked up in the press, recognized with awards, or even patented.</Paragraph>
    <ListView>
      {sortedAchievements.map((achievement) => (
        <ListViewItem>
          <ListViewItemImage 
            slot="image" 
            src={achievement.data.logo ? `/${achievement.data.logo}` : undefined}
            alt={`${achievement.data.title} logo`}
          />
          <Fragment slot="content">
            <ListViewItemTitle>{achievement.data.title}</ListViewItemTitle>
            <ListViewItemMeta class="text-stone-700 text-base md:hidden">{`${achievement.data.type} · ${achievement.data.author}`}</ListViewItemMeta>
            <ListViewItemMeta class="text-stone-500 text-sm md:hidden">{new Date(achievement.data.date).getFullYear()}</ListViewItemMeta>
            <ListViewItemMeta class="text-stone-500 text-base hidden md:block">{`${achievement.data.type} · ${achievement.data.author} · ${new Date(achievement.data.date).getFullYear()}`}</ListViewItemMeta>
          </Fragment>
          {achievement.data.url && (
            <ListViewItemLink href={achievement.data.url} slot="action">
              View
            </ListViewItemLink>
          )}
        </ListViewItem>
      ))}
    </ListView>
  </Section>
  <Section class="flex flex-col gap-y-2">
    <H2 class="font-semibold text-xl tracking-normal px-2">Education</H2>
    <ListView>
      {sortedEducation.map((education) => (
        <ListViewItem>
          <ListViewItemImage 
            slot="image" 
            src={education.data.logo ? `/${education.data.logo}` : undefined}
            alt={`${education.data.name} logo`}
          />
          <Fragment slot="content">
            <ListViewItemTitle>{education.data.name}</ListViewItemTitle>
            <ListViewItemMeta class="text-stone-700 text-base md:hidden">{education.data.qualification}</ListViewItemMeta>
            <ListViewItemMeta class="text-stone-500 text-sm md:hidden">{formatDateRange(education.data.startDate, education.data.endDate)}</ListViewItemMeta>
            <ListViewItemMeta class="text-stone-500 text-base hidden md:block">{`${education.data.qualification} · ${formatDateRange(education.data.startDate, education.data.endDate)}`}</ListViewItemMeta>
          </Fragment>
        </ListViewItem>
      ))}
    </ListView>
  </Section>
  <Section class="flex flex-col gap-y-2">
    <H2 class="font-semibold text-xl tracking-normal px-2">Appendix</H2>
    <Paragraph class="text-stone-700 px-2 pb-2">Sometimes there are notes, memories or information I want to share that don't quite fit anywhere else. This is the place for those things.</Paragraph>
    <ListView>
      {sortedAppendix.map((appendix) => (
        <ListViewItem href={`/appendix/${appendix.data.slug}`}>
          <Fragment slot="content">
            <ListViewItemTitle>{appendix.data.title}</ListViewItemTitle>
          </Fragment>
          <ListViewItemChevron slot="action" />
        </ListViewItem>
      ))}
    </ListView>
  </Section>
</Layout>
