---
import Heading from "@components/Heading.astro";
import HeadingLarge from "@components/HeadingLarge.astro";
import Link from "@components/Link.astro";
import ProfileImage from "@components/ProfileImage.astro";
import ListView from "@components/ListView.astro";
import ListViewDescription from "@components/ListViewDescription.astro";
import ListViewItem from "@components/ListViewItem.astro";
import ListViewItemChevron from "@components/ListViewItemChevron.astro";
import ListViewItemImage from "@components/ListViewItemImage.astro";
import ListViewItemMeta from "@components/ListViewItemMeta.astro";
import ListViewItemTitle from "@components/ListViewItemTitle.astro";
import Text from "@components/Text.astro";
import TextLink from "@components/TextLink.astro";
import View from "@components/View.astro";
import Group from "@components/Group.astro";
import { Layout } from "@layouts";
import { getSectionCollection } from "@utils/getSectionCollection";
import TextButtonLarge from "@components/TextButtonLarge.astro";

export const prerender = true;

const [
  experienceSection,
  mentorshipSection,
  projectsSection,
  achievementsSection,
  educationSection
] = await Promise.all([
  getSectionCollection("experience"),
  getSectionCollection("mentorship"),
  getSectionCollection("projects"),
  getSectionCollection("achievements"),
  getSectionCollection("education")
]);
---

<Layout
  title="Home | Jonathon Toon | Software Designer & Product Leader"
  description="Jonathon Toon is a versatile software designer and product leader based in Aotearoa New Zealand."
  keywords="design, software, product, fractional, leadership, new zealand, aotearoa, technology, typescript, start ups, engineering, mentorship, coaching, adplist"
  twitterHandle="@jonathontoon"
  canonicalUrl="https://www.jonathontoon.com/"
  ogImage="/images/og-image.png"
>
  <Group>
    <View class="shrink-1 flex px-2">
      <Link href="/" class="flex">
        <ProfileImage />
      </Link>
    </View>
  </Group>
  <Group>
    <HeadingLarge class="px-2">Hello,<br />I’m Jonathon.</HeadingLarge>
    <Text class="px-2"
      >I'm a software designer and product leader based in Aotearoa New Zealand.
      I see great design as the result of even greater synthesis, the process of
      balancing technology, context, and human desire.</Text
    >
    <View class="flex flex-col justify-start gap-4 px-2 pt-8 md:flex-row">
      <TextButtonLarge
        href="mailto:hi@jonathontoon.com"
        class="flex items-center justify-center gap-3 bg-stone-900 fill-stone-50 text-stone-50 hover:bg-stone-700 dark:bg-stone-100 dark:fill-stone-900 dark:text-stone-900 dark:hover:bg-stone-300"
      >
        <svg
          class="h-6 w-6"
          viewBox="0 0 24 24"
          fill="currentColor"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M1.51381 7.16523C1.50466 7.27561 1.5 7.38726 1.5 7.5V16.5C1.5 18.7091 3.29086 20.5 5.5 20.5H18.5C20.7091 20.5 22.5 18.7091 22.5 16.5V7.5C22.5 7.38744 22.4953 7.27596 22.4862 7.16576C22.5222 6.95155 22.4888 6.72592 22.3805 6.52549C21.9453 4.78734 20.373 3.5 18.5 3.5H5.5C3.62683 3.5 2.05439 4.78756 1.61944 6.52594C1.51136 6.72609 1.478 6.95135 1.51381 7.16523ZM3.5 15.5858L7.29289 11.7929C7.29659 11.7892 7.3003 11.7855 7.30404 11.7819L3.5 8.97895V15.5858ZM8.89223 12.9522C8.84564 13.0441 8.78393 13.1303 8.70711 13.2071L4.20711 17.7071C4.15105 17.7632 4.09 17.8112 4.02538 17.8511C4.391 18.25 4.9163 18.5 5.5 18.5H18.5C19.0837 18.5 19.609 18.25 19.9746 17.8511C19.91 17.8112 19.8489 17.7632 19.7929 17.7071L15.2929 13.2071C15.2161 13.1303 15.1544 13.0441 15.1078 12.9522L13.1865 14.368C12.481 14.8878 11.5192 14.8878 10.8137 14.368L8.89223 12.9522ZM20.5 8.97904V15.5858L16.7071 11.7929L16.696 11.782L20.5 8.97904ZM20.3053 6.6382C19.9834 5.96501 19.296 5.5 18.5 5.5H5.5C4.70404 5.5 4.01667 5.96498 3.69472 6.63813L12.0001 12.7579L20.3053 6.6382Z"
          ></path>
        </svg>
        Say Hello
      </TextButtonLarge>
      <TextButtonLarge
        href="https://x.com/intent/user?screen_name=jonathontoon"
        target="_blank"
        rel="me"
        class="flex items-center justify-center gap-3 border-2 border-stone-900 bg-transparent text-stone-900 hover:border-stone-700 hover:bg-transparent hover:text-stone-700 dark:border-stone-100 dark:text-stone-100 dark:hover:border-stone-300 dark:hover:text-stone-300"
      >
        <svg
          class="h-6 w-6"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
          <path d="M4 4l11.733 16h4.267l-11.733 -16z"></path>
          <path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"></path>
        </svg>
        Follow Me
      </TextButtonLarge>
    </View>
  </Group>
  <Group>
    <View class="px-2">
      <View class="h-px w-full bg-stone-200 dark:bg-stone-700" />
    </View>
  </Group>
  <Group>
    <Heading class="px-2">Experience</Heading>
    <Text class="px-2 pb-2"
      >For over 15 years I’ve worked with companies across Asia, Oceania, and
      North America. Through a combination of hands-on product, marketing and
      engineering expertise I've led and cultivated teams, while taking
      products from 0 to 1.</Text
    >
    <ListView>
      {
        experienceSection.map((experience) => (
          <ListViewItem
            href={experience.path || experience.url}
            target={experience.path ? undefined : "_blank"}
          >
            <ListViewItemImage
              slot="image"
              src={experience.logo ? `/${experience.logo}` : undefined}
              alt={`${experience.title} logo`}
            />
            <Fragment slot="content">
              <ListViewItemTitle>{experience.title}</ListViewItemTitle>
              <ListViewDescription>{experience.subtitle}</ListViewDescription>
              <ListViewItemMeta>{experience.date}</ListViewItemMeta>
            </Fragment>
            <ListViewItemChevron slot="action" external={!experience.path} />
          </ListViewItem>
        ))
      }
    </ListView>
  </Group>
  <Group>
    <View class="px-2">
      <View class="h-px w-full bg-stone-200 dark:bg-stone-700" />
    </View>
  </Group>
  <Group>
    <Heading class="px-2">Mentorship</Heading>
    <Text class="px-2 pb-2"
      >I help designers, product people, and founders untangle challenges
      through honest, actionable mentorship. Whether you're just starting a
      career or navigating an existing one, I offer advice tailored to any goal.</Text
    >
    <ListView>
      {
        mentorshipSection.map((mentorship) => (
          <ListViewItem href={mentorship.url} target="_blank">
            <ListViewItemImage
              slot="image"
              src={mentorship.logo ? `/${mentorship.logo}` : undefined}
              alt={`${mentorship.title} logo`}
            />
            <Fragment slot="content">
              <ListViewItemTitle>{mentorship.title}</ListViewItemTitle>
              <ListViewDescription>{mentorship.subtitle}</ListViewDescription>
              <ListViewItemMeta>{mentorship.date}</ListViewItemMeta>
            </Fragment>
            <ListViewItemChevron slot="action" />
          </ListViewItem>
        ))
      }
    </ListView>
  </Group>
  <Group>
    <View class="px-2">
      <View class="h-px w-full bg-stone-200 dark:bg-stone-700" />
    </View>
  </Group>
  <Group>
    <Heading class="px-2">Projects</Heading>
    <Text class="px-2 pb-2"
      >I believe designers are made better by deeply engaging with the materials
      at hand. This is why I enjoy taking the time to build things and
      experimenting with ideas.</Text
    >
    <ListView>
      {
        projectsSection.map((project) => (
          <ListViewItem href={project.url} target="_blank">
            <ListViewItemImage
              slot="image"
              src={project.logo ? `/${project.logo}` : undefined}
              alt={`${project.title} logo`}
            />
            <Fragment slot="content">
              <ListViewItemTitle>{project.title}</ListViewItemTitle>
              <ListViewDescription>{project.subtitle}</ListViewDescription>
              <ListViewItemMeta>{project.date}</ListViewItemMeta>
            </Fragment>
            <ListViewItemChevron slot="action" />
          </ListViewItem>
        ))
      }
    </ListView>
  </Group>
  <Group>
    <View class="px-2">
      <View class="h-px w-full bg-stone-200 dark:bg-stone-700" />
    </View>
  </Group>
  <Group>
    <Heading class="px-2">Achievements</Heading>
    <Text class="px-2 pb-2"
      >Highlights from my career and education which have been picked up in the
      press, recognized with awards, or even patented.</Text
    >
    <ListView>
      {
        achievementsSection.map((achievement) => (
          <ListViewItem href={achievement.url} target="_blank">
            <ListViewItemImage
              slot="image"
              src={achievement.logo ? `/${achievement.logo}` : undefined}
              alt={`${achievement.title} logo`}
            />
            <Fragment slot="content">
              <ListViewItemTitle>{achievement.title}</ListViewItemTitle>
              <ListViewDescription>{achievement.subtitle}</ListViewDescription>
              <ListViewItemMeta>{achievement.date}</ListViewItemMeta>
            </Fragment>
            <ListViewItemChevron slot="action" />
          </ListViewItem>
        ))
      }
    </ListView>
  </Group>
  <Group>
    <View class="px-2">
      <View class="h-px w-full bg-stone-200 dark:bg-stone-700" />
    </View>
  </Group>
  <Group>
    <Heading class="px-2 pb-2">Education</Heading>
    <ListView>
      {
        educationSection.map((education) => (
          <ListViewItem href={education.url} target="_blank">
            <ListViewItemImage
              slot="image"
              src={education.logo ? `/${education.logo}` : undefined}
              alt={`${education.title} logo`}
            />
            <Fragment slot="content">
              <ListViewItemTitle>{education.title}</ListViewItemTitle>
              <ListViewDescription>{education.subtitle}</ListViewDescription>
              <ListViewItemMeta>{education.date}</ListViewItemMeta>
            </Fragment>
            <ListViewItemChevron slot="action" />
          </ListViewItem>
        ))
      }
    </ListView>
  </Group>
  <Group>
    <View class="px-2">
      <View class="h-px w-full bg-stone-200 dark:bg-stone-700" />
    </View>
  </Group>
  <Group>
    <Heading class="px-2">Contact</Heading>
    <Text class="px-2">
      I'm always interested to meet new people, learn new things and hear fresh
      perspectives. If you'd like to send me an <TextLink
        href="mailto:hi@jonathontoon.com"
        rel="me">email</TextLink
      > I'd be happy to write back. Otherwise you can follow me on <TextLink
        target="_blank"
        href="https://x.com/intent/user?screen_name=jonathontoon"
        rel="me">X</TextLink
      >, <TextLink
        target="_blank"
        href="https://bsky.app/profile/jonathontoon.com"
        rel="me">BlueSky</TextLink
      > or <TextLink
        target="_blank"
        href="https://www.linkedin.com/comm/mynetwork/discovery-see-all?usecase=PEOPLE_FOLLOWS&followMember=jonathontoon"
        rel="me">LinkedIn</TextLink
      >.
    </Text>
  </Group>
  <Group>
    <View class="px-2">
      <View class="h-px w-full bg-stone-200 dark:bg-stone-700" />
    </View>
  </Group>
  <Group>
    <Heading class="px-2 pb-2">Colophon</Heading>
    <Text class="px-2">
      Each page is typeset in Archivo by <TextLink
        href="https://www.omnibus-type.com/"
        target="">Omnibus Type</TextLink
      >. Try it yourself on <TextLink
        href="https://fonts.google.com/specimen/Archivo?query=Omnibus-Type"
        target="_blank">Google Fonts</TextLink
      >. The icons used are from the wonderful <TextLink
        href="https://minoradventures.lemonsqueezy.com?aff=zOG5V"
        target="_blank">Amicons</TextLink
      > set, by Marek Minor. Grab your own copy <TextLink
        href="https://minoradventures.lemonsqueezy.com?aff=zOG5V"
        target="_blank">today</TextLink
      >.
    </Text>
    <Text class="px-2">
      Meeting scheduling and video calls for mentorship sessions are handled
      through <TextLink
        href="https://refer.cal.com/jonathontoon"
        target="_blank">Cal.com</TextLink
      >, while all payments are facilitated by <TextLink
        href="https://stripe.com/"
        target="_blank">Stripe</TextLink
      >.
    </Text>
    <Text class="px-2">
      The technology powering this website is <TextLink
        href="https://astro.build"
        target="_blank">Astro</TextLink
      >, a server-first framework that generates static pages. Hosting, and
      deployment are handled by <TextLink
        href="https://pages.cloudflare.com"
        target="_blank">Cloudflare</TextLink
      >.
    </Text>
    <Text class="px-2">
      All content provided under the <TextLink
        href="https://creativecommons.org/licenses/by-nc/4.0/"
        >CC BY-NC 4.0 license</TextLink
      > and was last updated {
        new Date().toLocaleDateString("en-US", {
          weekday: "long",
          year: "numeric",
          month: "long",
          day: "numeric"
        })
      }.
    </Text>
  </Group>
</Layout>
