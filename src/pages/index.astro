---
import Heading from "@components/Heading.astro";
import HeadingLarge from "@components/HeadingLarge.astro";
import Link from "@components/Link.astro";
import ProfileImage from "@components/ProfileImage.astro";
import ListView from "@components/ListView.astro";
import ListViewDescription from "@components/ListViewDescription.astro";
import ListViewItem from "@components/ListViewItem.astro";
import ListViewItemChevron from "@components/ListViewItemChevron.astro";
import ListViewItemImage from "@components/ListViewItemImage.astro";
import ListViewItemMeta from "@components/ListViewItemMeta.astro";
import ListViewItemTitle from "@components/ListViewItemTitle.astro";
import Text from "@components/Text.astro";
import TextLink from "@components/TextLink.astro";
import View from "@components/View.astro";
import Group from "@components/Group.astro";
import { Layout } from "@layouts";
import { getSectionCollection } from "@utils/getSectionCollection";
import TextButtonLarge from "@components/TextButtonLarge.astro";
import { Icon } from "astro-icon/components";

const experienceSection = await getSectionCollection("experience");
const mentorshipSection = await getSectionCollection("mentorship");
const projectsSection = await getSectionCollection("projects");
const achievementsSection = await getSectionCollection("achievements");
const educationSection = await getSectionCollection("education");
---

<Layout
  title="Home | Jonathon Toon | Software Designer, Product Leader"
  description="Jonathon Toon is a versatile software designer and product leader, currently based in Aotearoa New Zealand."
  keywords="design, software, product, fractional, leadership, new zealand, aoteoroa, technology, typescript, start ups, engineering, mentorship, coaching, adplist"
  twitterHandle="@jonathontoon"
  canonicalUrl="https://www.jonathontoon.com/"
  ogImage="/images/og-image.png"
>
  <Group>
    <View class="px-2">
      <Link href="/" class="flex">
        <ProfileImage />
      </Link>
    </View>
  </Group>
  <Group>
    <HeadingLarge class="block px-2 md:hidden"
      >Hello, I'm Jonathon.</HeadingLarge
    >
    <HeadingLarge class="hidden px-2 md:block"
      >Nice to meet you, I'm Jonathon.</HeadingLarge
    >
    <Text class="px-2"
      >A versatile software designer and product leader, currently based in Aotearoa New
      Zealand. I believe good design is the result of great synthesis, the right mix of technology, context, and desire.</Text
    >
    <Text class="px-2 indent-4"
      >For the past 15 years, I've worked across the organizational stack
      cultivating and leading teams, while designing and shipping products at
      innovative companies in Asia, Oceania, and North America.</Text
    >
    <Text class="px-2 indent-4"
      >In that time, I've built deep, hands-on expertise in product, brand and
      engineering, and learned how to bring those disciplines together to create
      products that matter.</Text
    >
    <View class="flex flex-col md:flex-row justify-start px-2 pt-8 gap-4">
      <TextButtonLarge href="/work" class="gap-3 flex items-center justify-center  text-stone-50 bg-stone-900 hover:bg-stone-700">
        <Icon
          name="solid-book-open"
          class="h-6 w-6"
        />
        View Work
      </TextButtonLarge>
      <TextButtonLarge href="mailto:hi@jonathontoon.com" class="gap-3 flex items-center justify-center text-stone-900 hover:text-stone-700 border-2 border-stone-900 hover:border-stone-700 bg-transparent hover:bg-transparent">
        <Icon
          name="stroke-email"
          class="h-6 w-6"
        />
        Get In Touch
      </TextButtonLarge>
    </View>
  </Group>
  <Group>
    <View class="px-2">
      <View class="w-full h-px bg-stone-200" />
    </View>
  </Group>
  <Group>
    <Heading class="px-2 text-xl tracking-normal">Experience</Heading>
    <ListView>
      {
        experienceSection.map((experience) => (
          <ListViewItem
            target="_blank"
            href={experience.url}
          >
            <ListViewItemImage
              slot="image"
              src={experience.logo ? `/${experience.logo}` : undefined}
              alt={`${experience.title} logo`}
            />
            <Fragment slot="content">
              <ListViewItemTitle>{experience.title}</ListViewItemTitle>
              <ListViewDescription class="text-stone-700 md:hidden">
                {experience.subtitle}
              </ListViewDescription>
              <ListViewItemMeta class="text-stone-500 md:hidden">
                {experience.date}
              </ListViewItemMeta>
              <ListViewDescription class="hidden text-stone-500 md:block">{`${experience.subtitle} · ${experience.date}`}</ListViewDescription>
            </Fragment>
            <ListViewItemChevron slot="action" />
          </ListViewItem>
        ))
      }
    </ListView>
  </Group>
  <Group>
    <View class="px-2">
      <View class="w-full h-px bg-stone-200" />
    </View>
  </Group>
  <Group>
    <Heading class="px-2 text-xl tracking-normal">Mentorship</Heading>
    <Text class="px-2 pb-2"
      >Through both one-off and recurring sessions I help designers, product
      people and founders navigate challenges through practical, honest,
      actionable mentorship.</Text
    >
    <ListView>
      {
        mentorshipSection.map((mentorship) => (
          <ListViewItem href={mentorship.url} target="_blank">
            <ListViewItemImage
              slot="image"
              src={mentorship.logo ? `/${mentorship.logo}` : undefined}
              alt={`${mentorship.title} logo`}
            />
            <Fragment slot="content">
              <ListViewItemTitle>{mentorship.title}</ListViewItemTitle>
              <ListViewDescription class="text-stone-700 md:hidden">
                {mentorship.subtitle}
              </ListViewDescription>
              <ListViewItemMeta class="text-sm text-stone-500 md:hidden">
                {mentorship.date}
              </ListViewItemMeta>
              <ListViewDescription class="hidden text-stone-500 md:block">{`${mentorship.subtitle} · ${mentorship.date}`}</ListViewDescription>
            </Fragment>
            <ListViewItemChevron slot="action" />
          </ListViewItem>
        ))
      }
    </ListView>
  </Group>
  <Group>
    <View class="px-2">
      <View class="w-full h-px bg-stone-200" />
    </View>
  </Group>
  <Group>
    <Heading class="px-2 text-xl tracking-normal">Projects</Heading>
    <Text class="px-2 pb-2"
      >I believe designers should intimately understand the materials they
      work with. That’s why I love building things myself. Whether to explore
      new technology or just for fun.</Text
    >
    <ListView>
      {
        projectsSection.map((project) => (
          <ListViewItem href={project.url} target="_blank">
            <ListViewItemImage
              slot="image"
              src={project.logo ? `/${project.logo}` : undefined}
              alt={`${project.title} logo`}
            />
            <Fragment slot="content">
              <ListViewItemTitle>{project.title}</ListViewItemTitle>
              <ListViewDescription class="text-stone-700 md:hidden">
                {project.subtitle}
              </ListViewDescription>
              <ListViewItemMeta class="text-sm text-stone-500 md:hidden">
                {project.date}
              </ListViewItemMeta>
              <ListViewDescription class="hidden text-stone-500 md:block">{`${project.subtitle} · ${project.date}`}</ListViewDescription>
            </Fragment>
            <ListViewItemChevron slot="action" />
          </ListViewItem>
        ))
      }
    </ListView>
  </Group>
  <Group>
    <View class="px-2">
      <View class="w-full h-px bg-stone-200" />
    </View>
  </Group>
  <Group>
    <Heading class="px-2 text-xl tracking-normal"
      >Patents, Publications, Awards</Heading
    >
    <Text class="px-2 pb-2"
      >Highlights from my career and education which have been picked up in the
      press, recognized with awards, or even patented.</Text
    >
    <ListView>
      {
        achievementsSection.map((achievement) => (
          <ListViewItem href={achievement.url} target="_blank">
            <ListViewItemImage
              slot="image"
              src={achievement.logo ? `/${achievement.logo}` : undefined}
              alt={`${achievement.title} logo`}
            />
            <Fragment slot="content">
              <ListViewItemTitle>{achievement.title}</ListViewItemTitle>
              <ListViewDescription class="text-stone-700 md:hidden">
                {achievement.subtitle}
              </ListViewDescription>
              <ListViewItemMeta class="text-sm text-stone-500 md:hidden">
                {achievement.date}
              </ListViewItemMeta>
              <ListViewDescription class="hidden text-stone-500 md:block">{`${achievement.subtitle} · ${achievement.date}`}</ListViewDescription>
            </Fragment>
            <ListViewItemChevron slot="action" />
          </ListViewItem>
        ))
      }
    </ListView>
  </Group>
  <Group>
    <View class="px-2">
      <View class="w-full h-px bg-stone-200" />
    </View>
  </Group>
  <Group>
    <Heading class="px-2 text-xl tracking-normal">Education</Heading>
    <ListView>
      {
        educationSection.map((education) => (
          <ListViewItem href={education.url} target="_blank">
            <ListViewItemImage
              slot="image"
              src={education.logo ? `/${education.logo}` : undefined}
              alt={`${education.title} logo`}
            />
            <Fragment slot="content">
              <ListViewItemTitle>{education.title}</ListViewItemTitle>
              <ListViewDescription class="text-stone-700 md:hidden">
                {education.subtitle}
              </ListViewDescription>
              <ListViewItemMeta class="text-sm text-stone-500 md:hidden">
                {education.date}
              </ListViewItemMeta>
              <ListViewDescription class="hidden text-stone-500 md:block">{`${education.subtitle} · ${education.date}`}</ListViewDescription>
            </Fragment>
            <ListViewItemChevron slot="action" />
          </ListViewItem>
        ))
      }
    </ListView>
  </Group>
  <Group>
    <View class="px-2">
      <View class="w-full h-px bg-stone-200" />
    </View>
  </Group>
  <Group>
    <Heading class="px-2 text-xl tracking-normal">Contact</Heading>
    <Text class="px-2">
      I'm always keen to meet new people, learn new things and hear fresh perspectives. With that, I'd be happy to write back if you'd like to send me an <TextLink href="mailto:hi@jonathontoon.com">email</TextLink>. Otherwise you can follow me on <TextLink target="_blank" class="decoration-2 line-through" target="_blank" href="https://x.com/intent/user?screen_name=jonathontoon">Twitter</TextLink>, <TextLink target="_blank" href="https://bsky.app/profile/jonathontoon.com">BlueSky</TextLink> or <TextLink target="_blank" href="https://www.linkedin.com/comm/mynetwork/discovery-see-all?usecase=PEOPLE_FOLLOWS&followMember=jonathontoon">LinkedIn</TextLink>. 
    </Text>
  </Group>
  <Group>
    <View class="px-2">
      <View class="w-full h-px bg-stone-200" />
    </View>
  </Group>
  <Group>
    <Heading class="px-2 text-xl tracking-normal">Colophon</Heading>
    <Text class="px-2">
      Each page is typeset in Archivo by <TextLink
        href="https://www.omnibus-type.com/"
        target="">Omnibus Type</TextLink
      >. Try it yourself on <TextLink
        href="https://fonts.google.com/specimen/Archivo?query=Omnibus-Type"
        target="_blank">Google Fonts</TextLink
      >. The icons used are from the wonderful <TextLink
        href="https://minoradventures.lemonsqueezy.com?aff=zOG5V"
        target="_blank">Amicons</TextLink
      > set, by Marek Minor. Grab your own copy <TextLink
        href="https://minoradventures.lemonsqueezy.com?aff=zOG5V"
        target="_blank">today</TextLink
      >.
    </Text>
    <Text class="px-2 indent-4">
      Meeting scheduling and video calls for mentorship sessions are handled
      through <TextLink
        href="https://refer.cal.com/jonathontoon"
        target="_blank">Cal.com</TextLink
      >, while all payments are facilitated by <TextLink
        href="https://stripe.com/"
        target="_blank">Stripe</TextLink
      >.
    </Text>
    <Text class="px-2 indent-4">
      The technology powering this website is <TextLink
        href="https://astro.build"
        target="_blank">Astro</TextLink
      >, a server-first framework that generates static pages. Hosting,
      deployment and analytics are all provided by <TextLink
        href="https://pages.cloudflare.com"
        target="_blank">Cloudflare</TextLink
      >.
    </Text>
    <Text class="px-2 indent-4">
      All content provided under the <TextLink
        href="https://creativecommons.org/licenses/by-nc/4.0/"
        >CC BY-NC 4.0 license</TextLink
      > and was last updated {
        new Date().toLocaleDateString("en-US", {
          weekday: "long",
          year: "numeric",
          month: "long",
          day: "numeric"
        })
      }.
    </Text>
  </Group>
</Layout>
