---
import Heading from "@components/Heading.astro";
import HeadingLarge from "@components/HeadingLarge.astro";
import ImageLarge from "@components/ImageLarge.astro";
import Link from "@components/Link.astro";
import ListView from "@components/ListView.astro";
import ListViewDescription from "@components/ListViewDescription.astro";
import ListViewItem from "@components/ListViewItem.astro";
import ListViewItemChevron from "@components/ListViewItemChevron.astro";
import ListViewItemImage from "@components/ListViewItemImage.astro";
import ListViewItemLink from "@components/ListViewItemLink.astro";
import ListViewItemMeta from "@components/ListViewItemMeta.astro";
import ListViewItemTitle from "@components/ListViewItemTitle.astro";
import Text from "@components/Text.astro";
import TextButtonLarge from "@components/TextButtonLarge.astro";
import TextLink from "@components/TextLink.astro";
import View from "@components/View.astro";
import ViewGroup from "@components/ViewGroup.astro";
import { Layout } from "@layouts";
import { getSectionCollection } from "@utils/getSectionCollection";
import { Icon } from "astro-icon/components";

const experienceSection = await getSectionCollection("experience");
const mentorshipSection = await getSectionCollection("mentorship");
const projectsSection = await getSectionCollection("projects");  
const achievementsSection = await getSectionCollection("achievements");
const educationSection = await getSectionCollection("education");
const contactSection = await getSectionCollection("contact");
---

<Layout
  title="Jonathon Toon | Home"
  description="Jonathon Toon is a software designer, leader, and mentor, living and working remotely in Aotearoa New Zealand. He has a passion for creating impactful digital experiences and fostering innovation in teams."
  keywords="design, software, product, fractional, leadership, new zealand, aoteoroa, technology, typescript, start ups, engineering, mentorship, coaching, adplist"
  twitterHandle="@jonathontoon"
  canonicalUrl="https://www.jonathontoon.com/"
  ogImage="/images/og-image.png"
>
<ViewGroup>
      <View class="px-2">
        <Link href="/">
          <ImageLarge src={"/images/profile.png"} alt="Jonathon Toon" class="bg-blue-500" />
        </Link>
      </View>
    </ViewGroup>
    <ViewGroup>
      <HeadingLarge class="font-semibold text-2xl tracking-tight px-2">Nice to meet you, I'm Jonathon.</HeadingLarge>
      <Text class="text-stone-700 px-2">A versatile software designer, leader, and mentor, living and working remotely in Aotearoa New Zealand.</Text>
      <Text class="text-stone-700 indent-4 px-2">For the past 15 years, I’ve worked across the organizational stack cultivating and leading teams, while designing and shipping products at innovative companies in Asia, Oceania, and North America.</Text>
      <Text class="text-stone-700 indent-4 px-2">In that time, I’ve built deep, hands-on expertise in product, brand and engineering, and learned how to bring those disciplines together to create products that make a real impact.</Text>  
    </ViewGroup>
    <ViewGroup>
      <Heading class="font-semibold text-xl tracking-normal px-2">Experience</Heading>
      <ListView>
        {experienceSection.map((experience) => (
          <ListViewItem href={experience.slug ? `/experience/${experience.slug}` : undefined}>
            <ListViewItemImage 
              slot="image" 
              src={experience.logo ? `/${experience.logo}` : undefined}
              alt={`${experience.title} logo`}
            />
            <Fragment slot="content">
              <ListViewItemTitle>{experience.title}</ListViewItemTitle>
              <ListViewDescription class="text-stone-700 md:hidden">{experience.subtitle}</ListViewDescription>
              <ListViewItemMeta class="text-stone-500 text-sm md:hidden">{experience.date}</ListViewItemMeta>
              <ListViewDescription class="text-stone-500 hidden md:block">{`${experience.subtitle} · ${experience.date}`}</ListViewDescription>
            </Fragment>
            {experience.url && (
              <ListViewItemLink href={experience.url} target="_blank" slot="action">
                {experience.urlText}
              </ListViewItemLink>
            )}
          </ListViewItem>
        ))}
      </ListView>
    </ViewGroup>
    <ViewGroup>
      <Heading class="font-semibold text-xl tracking-normal px-2">Mentorship</Heading>
      <Text class="text-stone-700 px-2 pb-2">Through both one-off and recurring sessions I help designers, product people and founders navigate challenges through practical, honest, actionable mentorship.</Text>
      <ListView>
        {mentorshipSection.map((mentorship) => (
          <ListViewItem>
            <ListViewItemImage 
              slot="image" 
              src={mentorship.logo ? `/${mentorship.logo}` : undefined}
              alt={`${mentorship.title} logo`}
            />
            <Fragment slot="content">
              <ListViewItemTitle>{mentorship.title}</ListViewItemTitle>
              <ListViewDescription class="text-stone-700 md:hidden">{mentorship.subtitle}</ListViewDescription>
              <ListViewItemMeta class="text-stone-500 text-sm md:hidden">{mentorship.date}</ListViewItemMeta>
              <ListViewDescription class="text-stone-500 hidden md:block">{`${mentorship.subtitle} · ${mentorship.date}`}</ListViewDescription>
            </Fragment>
            {mentorship.url && (
              <ListViewItemLink href={mentorship.url} target="_blank" slot="action">
                {mentorship.urlText}
              </ListViewItemLink>
            )}
          </ListViewItem>
        ))}
      </ListView>
    </ViewGroup>
    <ViewGroup>
      <Heading class="font-semibold text-xl tracking-normal px-2">Projects</Heading>
      <Text class="text-stone-700 px-2 pb-2">I love to build things on my own. Either to explore new technologies, to make a little pocket money, or simply just for fun.</Text>
      <ListView>
        {projectsSection.map((project) => (
          <ListViewItem>
            <ListViewItemImage 
              slot="image" 
              src={project.logo ? `/${project.logo}` : undefined}
              alt={`${project.title} logo`}
            />
            <Fragment slot="content">
              <ListViewItemTitle>{project.title}</ListViewItemTitle>
              <ListViewDescription class="text-stone-700 md:hidden">{project.subtitle}</ListViewDescription>
              <ListViewItemMeta class="text-stone-500 text-sm md:hidden">{project.date}</ListViewItemMeta>
              <ListViewDescription class="text-stone-500 hidden md:block">{`${project.subtitle} · ${project.date}`}</ListViewDescription>
            </Fragment>
            {project.url && (
              <ListViewItemLink href={project.url} target="_blank" slot="action">
                {project.urlText}
              </ListViewItemLink>
            )}
          </ListViewItem>
        ))}
      </ListView>
    </ViewGroup>
    <ViewGroup>
      <Heading class="font-semibold text-xl tracking-normal px-2">Patents, Publications, Awards</Heading>
      <Text class="text-stone-700 px-2 pb-2">Highlights from my career and education which have been picked up in the press, recognized with awards, or even patented.</Text>
      <ListView>
        {achievementsSection.map((achievement) => (
          <ListViewItem>
            <ListViewItemImage 
              slot="image" 
              src={achievement.logo ? `/${achievement.logo}` : undefined}
              alt={`${achievement.title} logo`}
            />
            <Fragment slot="content">
              <ListViewItemTitle>{achievement.title}</ListViewItemTitle>
              <ListViewDescription class="text-stone-700 md:hidden">{achievement.subtitle}</ListViewDescription>
              <ListViewItemMeta class="text-stone-500 text-sm md:hidden">{achievement.date}</ListViewItemMeta>
              <ListViewDescription class="text-stone-500 hidden md:block">{`${achievement.subtitle} · ${achievement.date}`}</ListViewDescription>
            </Fragment>
            {achievement.url && (
              <ListViewItemLink href={achievement.url} target="_blank" slot="action">
                {achievement.urlText}
              </ListViewItemLink>
            )}
          </ListViewItem>
        ))}
      </ListView>
    </ViewGroup>
    <ViewGroup>
      <Heading class="font-semibold text-xl tracking-normal px-2">Education</Heading>
      <ListView>
        {educationSection.map((education) => (
          <ListViewItem>
            <ListViewItemImage 
              slot="image" 
              src={education.logo ? `/${education.logo}` : undefined}
              alt={`${education.title} logo`}
            />
            <Fragment slot="content">
              <ListViewItemTitle>{education.title}</ListViewItemTitle>
              <ListViewDescription class="text-stone-700 md:hidden">{education.subtitle}</ListViewDescription>
              <ListViewItemMeta class="text-stone-500 text-sm md:hidden">{education.date}</ListViewItemMeta>
              <ListViewDescription class="text-stone-500 hidden md:block">{`${education.subtitle} · ${education.date}`}</ListViewDescription>
            </Fragment>
            {education.url && (
              <ListViewItemLink href={education.url} target="_blank" slot="action">
                {education.urlText}
              </ListViewItemLink>
            )}
          </ListViewItem>
        ))}
      </ListView>
    </ViewGroup>
    <ViewGroup>
      <Heading class="font-semibold text-xl tracking-normal px-2">Contact</Heading>
      <ListView>
        {contactSection.map((contact) => (
          <ListViewItem href={contact.url} target="_blank">
            <Fragment slot="content">
              <ListViewItemTitle>{contact.title}</ListViewItemTitle>
            </Fragment>
            <ListViewItemChevron slot="action" />
          </ListViewItem>
        ))}
      </ListView>
    </ViewGroup>
    <ViewGroup>
      <Heading class="font-semibold text-xl tracking-normal px-2">Colophon</Heading>
      <Text class="px-2">
        All visual elements are either designed by myself or their respective owners. Each page is typeset in Archivo by <TextLink href="https://www.omnibus-type.com/" target="">Omnibus Type</TextLink>. Try it yourself on <TextLink href="https://fonts.google.com/specimen/Archivo?query=Omnibus-Type" target="_blank">Google Fonts</TextLink>. The icons used are from the wonderful <TextLink href="https://minoradventures.lemonsqueezy.com?aff=zOG5V" target="_blank">Amicons</TextLink> set, by Marek Minor. Grab your own copy <TextLink href="https://minoradventures.lemonsqueezy.com?aff=zOG5V" target="_blank">today</TextLink>.
      </Text>
      <Text class="px-2 indent-4">
        The technology powering this website is <TextLink href="https://astro.build" target="_blank">Astro</TextLink>, a server-first framework that generates static pages. Hosting, deployment and analytics are all provided by <TextLink href="https://pages.cloudflare.com" target="_blank">Cloudflare</TextLink>.
      </Text>
      <Text class="px-2 indent-4">
        Meeting scheduling and video calls for mentorship sessions are handled through <TextLink href="https://refer.cal.com/jonathontoon" target="_blank">Cal.com</TextLink>, while all payments are facilitated by <TextLink href="https://stripe.com/" target="_blank">Stripe</TextLink>.
      </Text>
      <Text class="px-2 indent-4">
        All content provided under the <TextLink href="https://creativecommons.org/licenses/by-nc/4.0/">CC BY-NC 4.0 license</TextLink> and was last updated {new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}.
      </Text>
    </ViewGroup>
</Layout>
