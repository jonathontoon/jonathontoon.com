      lightbox={true} 
    />
  </Group>
  <Group>
    <Heading class="px-2">Moneytree for iOS</Heading>
    <Image
      src="/images/work/moneytree-ios.png"
      alt="Moneytree Vault"
      class="rounded-xl bg-stone-200 dark:bg-stone-800 w-full"
      lightbox={true} 
    />
    <Image
      src="/images/work/moneytree-ios-beeper.png"
      alt="Moneytree Vault"
      class="rounded-xl bg-stone-200 dark:bg-stone-800 w-full"
      lightbox={true} 
    />
  </Group>
</Layout>
