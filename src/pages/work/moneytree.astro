      lightbox={true} 
    />
  </Group>
  <Group>
    <Heading class="px-2">Yuchoreko</Heading>
    <Image
      src="/images/work/moneytree-yuchoreko-onboarding.png"
      alt="Moneytree Vault"
      class="rounded-xl bg-stone-200 dark:bg-stone-800 w-full"
      lightbox={true} 
    />
    <Image
      src="/images/work/moneytree-yuchoreko-main.png"
      alt="Moneytree Vault"
      class="rounded-xl bg-stone-200 dark:bg-stone-800 w-full"
      lightbox={true} 
