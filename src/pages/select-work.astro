---
import { Layout } from "@layouts";
import Group from "@components/Group.astro";
import Text from "@components/Text.astro";
import HeadingLarge from "@components/HeadingLarge.astro";
import WorkImage from "@components/WorkImage.astro";
import View from "@components/View.astro";
---

<Layout
  title="Experience | Jonathon Toon"
  description="A comprehensive look at Jonathon Toon's professional experience across design, product, and engineering roles at innovative companies."
  keywords="experience, career, software design, product design, leadership, technology companies, startups"
  twitterHandle="@jonathontoon"
  canonicalUrl="https://www.jonathontoon.com/experience/"
  ogImage="/images/og-image.png"
>
  <Group>
    <Text class="px-2">
      Highlights and select work from my 15+ years as a software designer and creative individual.
    </Text>
    <Text class="indent-4 px-2">
      Every product shown I either played a significant role as the most senior designer, the responsible individual executing the work, or was the leader accountable for both creative and business outcomes.
    </Text>
  </Group>
  <Group class="gap-y-6">
    <WorkImage
      src="/images/work/moneytree/moneytree-link-vault-1.png"
      alt="Moneytree App Screenshot"
      class="px-2"
    />
    <WorkImage
      src="/images/work/moneytree/moneytree-ios.png"
      alt="Moneytree App Screenshot"
      class="px-2"
    />
    <WorkImage
      src="/images/work/moneytree/moneytree-link-auth-2.png"
      alt="Moneytree App Screenshot"
      class="px-2"
    />
    <WorkImage
      src="/images/work/moneytree/moneytree-link-isshou-tsucho.png"
      alt="Moneytree App Screenshot"
      class="px-2"
    />
    <WorkImage
      src="/images/work/moneytree/moneytree-link-fast-onboarding.png"
      alt="Moneytree App Screenshot"
      class="px-2"
    />
    <WorkImage
      src="/images/work/moneytree/moneytree-business-cashflow-desktop.png"
      alt="Moneytree App Screenshot"
      class="px-2"
    />
    <WorkImage
      src="/images/work/moneytree/moneytree-business-account-desktop.png"
      alt="Moneytree App Screenshot"
      class="px-2"
    />
  </Group>
</Layout>
