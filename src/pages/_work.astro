---
import { Layout } from "@layouts";
import Group from "@components/Group.astro";
import HeadingLarge from "@components/HeadingLarge.astro";
import WorkImage from "@components/WorkImage.astro";
import View from "@components/View.astro";
import Text from "@components/Text.astro";
---

<Layout
  title="Select Work | Jonathon Toon | Software Designer, Product Leader"
  description="Jonathon Toon is a versatile software designer and product leader, currently based in Aotearoa New Zealand."
  keywords="design, software, product, fractional, leadership, new zealand, aoteoroa, technology, typescript, start ups, engineering, mentorship, coaching, adplist"
  twitterHandle="@jonathontoon"
  canonicalUrl="https://www.jonathontoon.com/experience/"
  ogImage="/images/og-image.png"
>
  <Group>
    <HeadingLarge class="px-2">Select Work</HeadingLarge>
    <Text class="px-2">
      Highlights from my career designing software products, including some used by millions of people. In each case I was either the lead designer, the person doing the work, or the leader responsible for the creative and business outcome of the experience.
    </Text>
  </Group>
  <Group>
    <View class="flex flex-col px-2">
      <View class="w-full h-px bg-stone-200" />
    </View>
  </Group>
  <Group class="gap-y-4 md:gap-y-12">
    <!-- Starboard (2024) -->
    <View class="flex flex-col px-2">
      <WorkImage
        src="/images/work/starboard-website.png"
        alt="Starboard Website Screenshot"
      />
      <!-- <HeadingSmall class="mt-4">Starboard Website</HeadingSmall>
      <Text class="flex">Starboard Website (2024). Landing page and marketing site design.</Text> -->
    </View>

    <!-- Moneytree (2021-2024) -->
    <View class="flex flex-col px-2">
      <WorkImage
        src="/images/work/moneytree-business-cashflow-desktop.png"
        alt="Moneytree Business Cashflow Screenshot"
      />
      <!-- <HeadingSmall class="mt-4">Moneytree Business</HeadingSmall>
      <Text class="flex">Moneytree's premier small business product that turns complex financial data into something business owners can actually use to understand their cash flow and make decisions. The forecasting tools ended up being particularly useful for accountants.</Text> -->
    </View>
    <View class="flex flex-col px-2">
      <WorkImage
        src="/images/work/moneytree-link-vault.png"
        alt="Moneytree LINK Vault Screenshot"
      />
      <!-- <HeadingSmall class="mt-4">Moneytree LINK Vault</HeadingSmall>
      <Text class="flex">The core interface for accessing and managing financial data from across 2000+ institutions. It was one of the foundational product experiences that helped Moneytree to grow the LINK platform to over over 120 customers. Including banks, insurance companies, and lenders.</Text> -->
    </View>
    <View class="flex flex-col px-2">
      <WorkImage
        src="/images/work/moneytree-link-auth.png"
        alt="Moneytree LINK Authorization Screenshot"
      />
      <!-- <HeadingSmall class="mt-4">Moneytree LINK OAuth</HeadingSmall>
      <Text class="flex">The way in which users on Moneytree authorized sharing their financial data with third parties. The design had to balance strict regulatory requirements with keeping people comfortable about sharing sensitive information. It became the standard that other fintech companies in Japan ended up following.</Text> -->
    </View>
    <View class="flex flex-col px-2">
      <WorkImage
        src="/images/work/moneytree-link-isshou-tsucho.png"
        alt="Moneytree Isshou Tsucho Screenshot"
      />
      <!-- <HeadingSmall class="mt-4">一生通帳 by Moneytree</HeadingSmall>
      <Text class="flex">Moneytree's white-label banking product, which translates to "Lifetime Bankbook." Built for traditional Japanese banks to offer to their customers. At its peak, it was running on over 20 regional bank websites. Interesting work adapting modern fintech for very conservative banking customers.</Text> -->
    </View>
    <View class="flex flex-col px-2">
      <WorkImage
        src="/images/work/moneytree-link-fast-onboarding.png"
        alt="Moneytree Fast Onboarding Screenshot"
      />
      <!-- <HeadingSmall class="mt-4">Moneytree Fast Onboarding</HeadingSmall>
      <Text class="flex">Fast Onboarding (2018). Streamlined user setup process for faster account connection.</Text> -->
    </View>
    <View class="flex flex-col px-2">
      <WorkImage
        src="/images/work/moneytree-ios.png"
        alt="Moneytree iOS App Screenshot"
      />
      <!-- <HeadingSmall class="mt-4">Moneytree for iOS</HeadingSmall>
      <Text class="flex">A redesign of Moneytree's original personal finance app that started back in 2012. The app had hundreds of thousands of loyal users in Japan, so the challenge was improving things without breaking what people already liked about it.</Text> -->
    </View>

    <!-- Rainforest QA (2020-2021) -->
    <View class="flex flex-col px-2">
      <WorkImage
        src="/images/work/rainforest-branding-logo.png"
        alt="Rainforest Branding Logo"
      />
      <!-- <HeadingSmall class="mt-4">Rainforest Branding</HeadingSmall>
      <Text class="flex">Rainforest Branding (2020). Brand identity and logo design for QA automation platform.</Text> -->
    </View>
    <View class="flex flex-col px-2">
      <WorkImage
        src="/images/work/rainforest-test-authoring.png"
        alt="Rainforest Test Authoring Screenshot"
      />
      <!-- <HeadingSmall class="mt-4">Rainforest Test Authoring</HeadingSmall>
      <Text class="flex">Rainforest Test Authoring (2020). Interface for creating and managing automated tests.</Text> -->
    </View>

    <!-- Origami (2015-2016) -->
    <View class="flex flex-col px-2">
      <WorkImage
        src="/images/work/origami-navigation.png"
        alt="Origami Navigation Screenshot"
      />
      <!-- <HeadingSmall class="mt-4">Origami Navigation</HeadingSmall>
      <Text class="flex">Origami Explore (2016). Intuitive navigation system for the payment platform.</Text> -->
    </View>
    <View class="flex flex-col px-2">
      <WorkImage
        src="/images/work/origami-pay.png"
        alt="Origami Pay Screenshot"
      />
      <!-- <HeadingSmall class="mt-4">Origami Pay</HeadingSmall>
      <Text class="flex">Origami Pay (2016). Mobile payment interface for seamless transactions.</Text> -->
    </View>

    <!-- Xero (2014-2015) -->
    <View class="flex flex-col px-2">
      <WorkImage
        src="/images/work/xero-me-onboarding.png"
        alt="Xero Me Onboarding Screenshot"
      />
      <!-- <HeadingSmall class="mt-4">Xero Me Onboarding</HeadingSmall>
      <Text class="flex">Xero Me Onboarding (2017). User onboarding flow for personal expense tracking.</Text> -->
    </View>
    <View class="flex flex-col px-2">
      <WorkImage
        src="/images/work/xero-me-request.png"
        alt="Xero Me Request Screenshot"
      />
      <!-- <HeadingSmall class="mt-4">Xero Me Request</HeadingSmall>
      <Text class="flex">Xero Me Request (2017). Expense request and approval interface.</Text> -->
    </View>

    <!-- Facebook (2012-2014) -->
    <View class="flex flex-col px-2">
      <WorkImage
        src="/images/work/facebook-composer.png"
        alt="Facebook Composer Screenshot"
      />
      <!-- <HeadingSmall class="mt-4">Facebook Composer</HeadingSmall>
      <Text class="flex">Composer for iOS (2014). Taking advantage of the increasing resolution of mobile devices, and the simplified photo selecting experience, a photo-tray was added, hidden under the keyboard, to the post composer for quick access when sharing content.</Text> -->
    </View>
    <View class="flex flex-col px-2">
      <WorkImage
        src="/images/work/facebook-simple-picker.png"
        alt="Facebook Simple Picker Screenshot"
      />
      <!-- <HeadingSmall class="mt-4">Facebook Simple Picker</HeadingSmall>
      <Text class="flex">Simple Picker for iOS (2014). With Instagram taking the spot as the space to share more curated photos, photo selection and sharing on Facebook became more about easily selecting and sharing what was most recent, with as little friction as possible.</Text> -->
    </View>
    <View class="flex flex-col px-2">
      <WorkImage
        src="/images/work/facebook-voice-calling.png"
        alt="Facebook Voice Calling Screenshot"
      />
      <!-- <HeadingSmall class="mt-4">Facebook Voice Calling</HeadingSmall>
      <Text class="flex">Voice Calling for iOS (2014). To take on Microsoft's Skype, Facebook created their own in-house technology to provide voice calling across iOS, Android and web.</Text> -->
    </View>
  </Group>
</Layout>
