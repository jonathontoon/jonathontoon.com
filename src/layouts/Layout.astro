---
import Breadcrumbs from "@components/Breadcrumbs.astro";
import Text from "@components/Text.astro";
import TextLink from "@components/TextLink.astro";
import View from "@components/View.astro";
import "@fontsource-variable/archivo";
import "@fontsource-variable/archivo-narrow";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  keywords?: string;
  twitterHandle?: string;
}

const { 
  title, 
  description = "Jonathon Toon | A software designer, leader and coach based in Aotearoa New Zealand.",
  canonicalUrl,
  ogImage,
  keywords = "design, software, product, fractional, leadership, new zealand, aoteoroa, technology, typescript, start ups, engineering, mentorship, coaching, adplist",
  twitterHandle = ""
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta content="IE=edge,chrome=1" http-equiv="X-UA-Compatible" />
    <meta
      name="description"
      content={description}
    />
    <meta
      content={keywords}
      name="keywords"
    />
    <meta content="dark light" name="color-scheme" />
    <meta content="#000000" name="theme-color" />
    <meta content="yes" name="mobile-web-app-capable" />
    <meta content="Jonathon Toon" name="apple-mobile-web-app-title" />
    <meta content="yes" name="apple-mobile-web-app-capable" />
    <meta
      content="black-translucent"
      name="apple-mobile-web-app-status-bar-style"
    />
    <meta content="Jonathon Toon" name="application-name" />
    <meta
      content={description}
      name="msapplication-tooltip"
    />
    <meta content="/" name="msapplication-starturl" />
    <meta content="#000000" name="msapplication-navbutton-color" />
    <meta content="#000000" name="msapplication-TileColor" />
    <meta content="browserconfig.xml" name="msapplication-config" />
    <meta content="images/favicon-144.png" name="msapplication-TileImage" />
    <meta content="no" name="msapplication-tap-highlight" />
    <meta content="yes" name="full-screen" />
    <meta content="application" name="browsermode" />
    <meta content={title} property="og:title" />
    <meta
      content={description}
      property="og:description"
    />
    <meta content="website" property="og:type" />
    <meta content={canonicalUrl || "https://www.jonathontoon.com/"} property="og:url" />
    {ogImage && (
      <>
        <meta content={ogImage} property="og:image" />
        <meta content="image/png" property="og:image:type" />
        <meta content="1200" property="og:image:width" />
        <meta content="630" property="og:image:height" />
      </>
    )}
    <meta content="summary" name="twitter:card" />
    <meta content={twitterHandle} name="twitter:site" />
    <meta content={canonicalUrl || "https://www.jonathontoon.com/"} name="twitter:url" />
    <meta content={title} name="twitter:title" />
    <meta
      content={description}
      name="twitter:description"
    />
    {ogImage && <meta content={ogImage} name="twitter:image" />}
    <link href="images/favicon.ico" rel="shortcut icon" type="image/x-icon" />
    <link
      href="images/favicon-16.png"
      rel="icon"
      sizes="16x16"
      type="image/png"
    />
    <link
      href="images/favicon-32.png"
      rel="icon"
      sizes="32x32"
      type="image/png"
    />
    <link
      href="images/favicon-48.png"
      rel="icon"
      sizes="48x48"
      type="image/png"
    />
    <link
      href="images/favicon-57.png"
      rel="icon"
      sizes="57x57"
      type="image/png"
    />
    <link
      href="images/favicon-76.png"
      rel="icon"
      sizes="76x76"
      type="image/png"
    />
    <link
      href="images/favicon-96.png"
      rel="icon"
      sizes="96x96"
      type="image/png"
    />
    <link
      href="images/favicon-128.png"
      rel="icon"
      sizes="128x128"
      type="image/png"
    />
    <link
      href="images/favicon-192.png"
      rel="icon"
      sizes="192x192"
      type="image/png"
    />
    <link
      href="images/favicon-228.png"
      rel="icon"
      sizes="228x228"
      type="image/png"
    />
    <link
      href="images/favicon-120.png"
      rel="apple-touch-icon"
      sizes="120x120"
    />
    <link
      href="images/favicon-152.png"
      rel="apple-touch-icon"
      sizes="152x152"
    />
    <link
      href="images/favicon-167.png"
      rel="apple-touch-icon"
      sizes="167x167"
    />
    <link
      href="images/favicon-180.png"
      rel="apple-touch-icon"
      sizes="180x180"
    />
    <link href="jonathontoon.webmanifest" rel="manifest" />
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="bg-stone-50 text-stone-900">
    <main class="flex flex-col max-w-xl px-3 md:px-6 mx-auto py-5 md:py-12 gap-y-8 md:gap-y-14">
      <slot />
      <footer class="flex flex-col gap-y-8 p-1">
        <View class="flex flex-row w-full justify-between">
          <Text class="text-stone-700">
            Thanks for stopping by.
          </Text>
          <Text class="text-stone-700">
            © {new Date().getFullYear()} Jonathon Toon
          </Text>
        </View>
      </footer>
    </main>
  </body>
</html>

{import.meta.env.PROD && (
  <script
    defer
    src="https://cloud.umami.is/script.js"
    data-website-id="e1d957f7-6fdb-4665-885c-fd9ec7fa871a">
  </script>
  <script is:inline>
    (function (h, o, t, j, a, r) {
      h.hj =
        h.hj ||
        function () {
          (h.hj.q = h.hj.q || []).push(arguments);
        };
      h._hjSettings = { hjid: 5022757, hjsv: 6 };
      a = o.getElementsByTagName("head")[0];
      r = o.createElement("script");
      r.async = 1;
      r.src = t + h._hjSettings.hjid + j + h._hjSettings.hjsv;
      if (a) a.appendChild(r);
    })(window, document, "https://static.hotjar.com/c/hotjar-", ".js?sv=");
  </script>
)}
<style is:global>
  * {
    backface-visibility: hidden;
    transform-style: preserve-3d;
    scroll-behavior: smooth;
    text-rendering: optimizeLegibility;
  }
</style>
