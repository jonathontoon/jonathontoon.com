---
import Text from "@components/Text.astro";
import View from "@components/View.astro";
import GlobalStyles from "@components/GlobalStyles.astro";
import Lightbox from "@components/Lightbox.astro";
import "@fontsource-variable/archivo";
import { ClientRouter } from "astro:transitions";
import ScrollView from "@components/ScrollView.astro";
import CloseButton from "@components/CloseButton.astro";

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  keywords?: string;
  twitterHandle?: string;
}

const { 
  title, 
  description = "Jonathon Toon | A software designer, leader and coach based in Aotearoa New Zealand.",
  canonicalUrl,
  ogImage,
  keywords = "design, software, product, fractional, leadership, new zealand, aoteoroa, technology, typescript, start ups, engineering, mentorship, coaching, adplist",
  twitterHandle = ""
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, user-scalable=yes" />
    <meta content="IE=edge,chrome=1" http-equiv="X-UA-Compatible" />
    <meta
      name="description"
      content={description}
    />
    <meta
      content={keywords}
      name="keywords"
    />
    <meta content="dark light" name="color-scheme" />
    <meta content="#fafaf9" name="theme-color" />
    <meta content="yes" name="mobile-web-app-capable" />
    <meta content="Jonathon Toon" name="apple-mobile-web-app-title" />
    <meta content="yes" name="apple-mobile-web-app-capable" />
    <meta
      content="black-translucent"
      name="apple-mobile-web-app-status-bar-style"
    />
    <meta content="Jonathon Toon" name="application-name" />
    <meta
      content={description}
      name="msapplication-tooltip"
    />
    <meta content="/" name="msapplication-starturl" />
    <meta content="#000000" name="msapplication-navbutton-color" />
    <meta content="#000000" name="msapplication-TileColor" />
    <meta content="browserconfig.xml" name="msapplication-config" />
    <meta content="images/favicon-144.png" name="msapplication-TileImage" />
    <meta content="no" name="msapplication-tap-highlight" />
    <meta content="yes" name="full-screen" />
    <meta content="application" name="browsermode" />
    <meta content={title} property="og:title" />
    <meta
      content={description}
      property="og:description"
    />
    <meta content="website" property="og:type" />
    <meta content={canonicalUrl || "https://www.jonathontoon.com/"} property="og:url" />
    {ogImage && (
      <>
        <meta content={ogImage} property="og:image" />
        <meta content="image/png" property="og:image:type" />
        <meta content="1200" property="og:image:width" />
        <meta content="630" property="og:image:height" />
      </>
    )}
    <meta content="summary" name="twitter:card" />
    <meta content={twitterHandle} name="twitter:site" />
    <meta content={canonicalUrl || "https://www.jonathontoon.com/"} name="twitter:url" />
    <meta content={title} name="twitter:title" />
    <meta
      content={description}
      name="twitter:description"
    />
    {ogImage && <meta content={ogImage} name="twitter:image" />}
    <link rel="icon" type="image/x-icon" href="/images/favicon/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/images/favicon/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/images/favicon/favicon-96x96.png" />
    <link rel="apple-touch-icon" href="/images/favicon/apple-touch-icon.png" />
    <link href="/jonathontoon.webmanifest" rel="manifest" />
    <link rel="preload" as="image" href="/images/profile.png" />
    <link rel="preload" as="image" href="/images/profile-blink.png" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
    <GlobalStyles />
  </head>
  <body class="overflow-hidden bg-stone-50 dark:bg-stone-900 text-stone-900 dark:text-stone-100 font-sans selection:bg-stone-900 selection:text-stone-50 dark:selection:bg-stone-100 dark:selection:text-stone-900 max-h-screen">
    <ScrollView>
      <main class="flex flex-col max-w-2xl px-3 md:px-6 mx-auto py-5 md:py-12 gap-y-12 md:gap-y-14"> 
        <slot />
        <footer class="flex flex-col gap-8 p-1">
          <View class="flex flex-col md:flex-row gap-2 w-full justify-between">
            <Text>
              © {new Date().getFullYear()}. Thanks for stopping by.
            </Text>
          </View>
        </footer>
      </main>
    </ScrollView>
    <Lightbox />
    <CloseButton currentPath={Astro.url.pathname} />
  </body>
</html>

{import.meta.env.PROD && (
  <script
    defer
    src="https://cloud.umami.is/script.js"
    data-website-id="e1d957f7-6fdb-4665-885c-fd9ec7fa871a">
  </script>
  <script is:inline>
    (function (h, o, t, j, a, r) {
      h.hj =
        h.hj ||
        function () {
          (h.hj.q = h.hj.q || []).push(arguments);
        };
      h._hjSettings = { hjid: 5022757, hjsv: 6 };
      a = o.getElementsByTagName("head")[0];
      r = o.createElement("script");
      r.async = 1;
      r.src = t + h._hjSettings.hjid + j + h._hjSettings.hjsv;
      if (a) a.appendChild(r);
    })(window, document, "https://static.hotjar.com/c/hotjar-", ".js?sv=");
  </script>
)}
